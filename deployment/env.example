# ==============================================================================
# AI FASHION OS - PRODUCTION COMPILATION ENVIRONMENT MANIFEST
# ==============================================================================

# 1. Core Service Binding Definition
NODE_ENV=production
PORT=3000

# 2. Hardened Session Security Configuration
# Safe token salt to protect against local integrity tampering
SESSION_INTEGRITY_SALT=9ff02a3a8b4f_ai_os_hardened_secret_salt

# 3. Dynamic Optimization Limits
# Maximum permitted render duration before fallback cache gets swappable
DEFAULT_NETWORK_TIMEOUT_MS=8000

# 4. Premium Gated Keys (Bypassed in Sandbox, Configured in Production Console)
VITE_MICROENGINE_ACCESS_KEY=

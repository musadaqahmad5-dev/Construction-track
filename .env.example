# =========================================================================
# SERVER-SIDE SECRETS (Never exposed to the browser)
# =========================================================================

# Google Gemini API key used for running server-side LLM inference
GEMINI_API_KEY=

# Firebase service account credentials (raw JSON string, path to file, or base64 string)
FIREBASE_SERVICE_ACCOUNT=

# Stripe API Secret key for subscription routing and order processing
STRIPE_SECRET_KEY=

# Stripe webhook signing secret to verify inbound Stripe events
STRIPE_WEBHOOK_SECRET=

# DB Host details if using Postgres SQL
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# JWT Signatures
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# =========================================================================
# CLIENT-SIDE ENVIRONMENT VARIABLES (Prefix VITE_ for compiler injection)
# =========================================================================

# Base API url to direct frontend requests (defaults to http://localhost:3000/api)
VITE_API_BASE_URL=

# Public Firebase config variables for standard web clients
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
